# Copy to .env and fill in. Loaded by both api and worker (DotNetEnv).

# ── Database ──────────────────────────────────────────────
DATABASE_URL=postgres://user:pass@localhost:5432/school_events

# ── Auth (JWT) ────────────────────────────────────────────
JWT_SECRET=change-me-to-a-random-32+-char-secret
JWT_ISSUER=school-events
JWT_AUDIENCE=school-events
JWT_EXPIRES_MINUTES=120

# ── SMTP (worker sends email) ─────────────────────────────
# For dev, Mailtrap or a local MailHog/Papercut on 1025 works well.
SMTP_HOST=localhost
SMTP_PORT=1025
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM=no-reply@school-events.local

# ── Worker ────────────────────────────────────────────────
WORKER_POLL_SECONDS=5
WORKER_MAX_ATTEMPTS=3

# ── Frontend ──────────────────────────────────────────────
# Base URL the static frontend uses to reach the API.
# (Mirror this value in frontend/app.js -> API_BASE_URL.)
API_BASE_URL=http://localhost:5080
