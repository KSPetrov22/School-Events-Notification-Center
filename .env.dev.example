# Local dev — real backend (BusinessLogicLayer2 + DataAccessLayer3 implemented)
# Copy to .env:  cp .env.dev.example .env

# ── Database ──────────────────────────────────────────────
DATABASE_URL=Data Source=DataAccessLayer3/Db/school_events.db

# ── Auth (JWT) ────────────────────────────────────────────
JWT_SECRET=dev-only-insecure-secret-change-before-any-real-deployment
JWT_ISSUER=school-events
JWT_AUDIENCE=school-events
JWT_EXPIRES_MINUTES=120

# ── SMTP — MailHog / Papercut on port 1025 for local email capture ────────
SMTP_HOST=localhost
SMTP_PORT=1025
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM=no-reply@school-events.local

# ── Worker ────────────────────────────────────────────────
WORKER_POLL_SECONDS=5
WORKER_MAX_ATTEMPTS=3

# ── Frontend ──────────────────────────────────────────────
MOCK_LOGIN=false
