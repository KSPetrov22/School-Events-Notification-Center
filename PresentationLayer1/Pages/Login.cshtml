@page
@model PresentationLayer1.Pages.LoginModel
@{
    ViewData["Title"] = "Login";
}

<div class="login-page">
  <section class="login-card">
    <div class="brand-icon" aria-hidden="true">🎓</div>
    @if (Model.IsMockLogin)
    {
      <h1>Welcome back</h1>
      <p class="muted">Pick a demo account to explore the platform while the real auth backend is being built.</p>
      <form method="post" class="stack">
        <label>
          Account
          <select asp-for="Email">
            <option value="student1@school.local">👨‍🎓 Student — student1@school.local</option>
            <option value="student2@school.local">👩‍🎓 Student — student2@school.local</option>
            <option value="student3@school.local">👨‍🎓 Student — student3@school.local</option>
            <option value="organizer1@school.local">📋 Organizer — organizer1@school.local</option>
          </select>
        </label>
        <button type="submit" class="accent">Sign in</button>
      </form>
      <div class="login-divider">Demo mode</div>
      <p class="muted" style="font-size:0.88rem;margin:0">No password required. Students can browse and register; organizers manage events.</p>
    }
    else
    {
      <h1>Sign in</h1>
      <p class="muted">Enter your school credentials to access events and registrations.</p>
      <form method="post" class="stack">
        <label>Email<input asp-for="Email" type="email" required placeholder="you@school.local" /></label>
        <label>Password<input asp-for="Password" type="password" required placeholder="••••••••" /></label>
        <span asp-validation-summary="All" class="notice error"></span>
        <button type="submit" class="accent">Sign in</button>
      </form>
    }
  </section>
</div>
