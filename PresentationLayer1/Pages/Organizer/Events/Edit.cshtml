@page "{id?}"
@model PresentationLayer1.Pages.Organizer.Events.EditModel
@{
    ViewData["Title"] = Model.Id is null ? "New event" : "Edit event";
}

<section class="panel narrow reveal">
  <span class="badge @(Model.Id is null ? "draft" : "published")">@(Model.Id is null ? "New" : "Editing")</span>
  <h1>@ViewData["Title"]</h1>
  <p class="muted">Fill in the details below. Events are saved as drafts until you publish them.</p>

  <form method="post" class="form-grid" style="margin-top:24px">
    <label>
      Title
      <input asp-for="Input.Title" placeholder="e.g. Robotics Workshop" />
      <span asp-validation-for="Input.Title" class="muted"></span>
    </label>
    <label>
      Description
      <textarea asp-for="Input.Description" rows="5" placeholder="What will participants learn or experience?"></textarea>
      <span asp-validation-for="Input.Description" class="muted"></span>
    </label>
    <label>
      Starts at
      <input asp-for="Input.StartsAt" placeholder="2026-06-15T10:00:00Z" />
      <span asp-validation-for="Input.StartsAt" class="muted"></span>
    </label>
    <label>
      Ends at
      <input asp-for="Input.EndsAt" placeholder="2026-06-15T12:00:00Z" />
      <span asp-validation-for="Input.EndsAt" class="muted"></span>
    </label>
    <label>
      Capacity
      <input asp-for="Input.Capacity" type="number" min="1" />
      <span asp-validation-for="Input.Capacity" class="muted"></span>
    </label>
    <label>
      Location or URL
      <input asp-for="Input.Location" placeholder="Room 204 or https://…" />
    </label>
    <div class="actions">
      <button type="submit" class="accent">Save draft</button>
      <a class="button secondary" asp-page="/Organizer/Events/Index">← Back</a>
    </div>
  </form>
</section>
