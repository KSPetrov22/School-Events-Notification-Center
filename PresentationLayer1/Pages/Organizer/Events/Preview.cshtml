@page "{id}"
@model PresentationLayer1.Pages.Organizer.Events.PreviewModel
@{
    ViewData["Title"] = "Preview";
}

@if (Model.Event is not null)
{
  <section class="panel">
    <p class="muted">Student preview</p>
    <h1>@Model.Event.Title</h1>
    <p>@Model.Event.Description</p>
    <dl class="meta">
      <div><dt>Starts</dt><dd>@Model.Event.StartsAt</dd></div>
      <div><dt>Ends</dt><dd>@Model.Event.EndsAt</dd></div>
      <div><dt>Location</dt><dd>@(Model.Event.Location ?? "TBA")</dd></div>
      <div><dt>Capacity</dt><dd>@Model.Event.Capacity</dd></div>
    </dl>
    <a class="button secondary" asp-page="/Organizer/Events/Index">Back</a>
  </section>
}

