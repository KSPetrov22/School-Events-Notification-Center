@page
@model PresentationLayer1.Pages.Organizer.Events.IndexModel
@{
    ViewData["Title"] = "Organizer events";
}

<section class="page-heading">
  <div>
    <h1>Organizer events</h1>
    <p class="muted">Manage drafts, publish events, and review signups.</p>
  </div>
  <a class="button" asp-page="/Organizer/Events/Edit">New event</a>
</section>

<div class="grid">
@foreach (var item in Model.Events)
{
  <article class="card">
    <div class="card-head">
      <h2>@item.Title</h2>
      <span class="badge @item.Status.ToLowerInvariant()">@item.Status</span>
      @if (item.IsFull)
      {
        <span class="badge cancelled">FULL</span>
      }
    </div>
    <p>@item.Description</p>
    <dl class="meta">
      <div><dt>Starts</dt><dd><time class="local-time" datetime="@item.StartsAt">@item.StartsAt</time></dd></div>
      <div><dt>Seats</dt><dd>@item.ConfirmedCount / @item.Capacity</dd></div>
      <div><dt>Waitlist</dt><dd>@item.WaitlistCount</dd></div>
      @if (!string.IsNullOrEmpty(item.Location))
      {
        <div><dt>Where</dt><dd>@item.Location</dd></div>
      }
    </dl>
    <div class="actions">
      @if (item.Status != "CANCELLED")
      {
        <a class="button secondary" asp-page="/Organizer/Events/Edit" asp-route-id="@item.Id">Edit</a>
      }
      <a class="button secondary" asp-page="/Organizer/Events/Preview" asp-route-id="@item.Id">Preview</a>
      <a class="button secondary" asp-page="/Organizer/Events/Registrations" asp-route-id="@item.Id">Signups</a>
      @if (item.Status == "PUBLISHED")
      {
        <a class="button secondary" asp-page="/Events/Details" asp-route-id="@item.Id" target="_blank">Public link</a>
        <button class="button secondary js-copy-link"
                data-url="@Url.Page("/Events/Details", new { id = item.Id })">Copy link</button>
      }
      @if (item.Status == "DRAFT")
      {
        <form method="post" asp-page-handler="Publish" asp-route-id="@item.Id">
          <button type="submit">Publish</button>
        </form>
      }
      @if (item.Status != "CANCELLED")
      {
        <form method="post" asp-page-handler="Cancel" asp-route-id="@item.Id">
          <button type="submit" class="danger">Cancel</button>
        </form>
      }
    </div>
  </article>
}
</div>

